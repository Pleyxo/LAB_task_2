    TRACKING_CONVERGE_PX = 8      # 锟斤拷目锟疥顶锟斤拷锟斤拷锟斤拷锟斤拷锟斤拷锟斤拷锟?锟斤拷锟斤拷"
    t = threading.Thread(target=stdin_listener, args=(mode_holder, serial_port), daemon=True)
    t.start()

    while True:
        frame = picam2.capture_array()
        mode = mode_holder.get('mode', 'align')

        raw_display = cv2.normalize(frame, None, 0, 255, cv2.NORM_MINMAX)
        if mode in ('align', 'black_frame'):
            display_frame = cv2.convertScaleAbs(raw_display, alpha=0.5, beta=-20)
        else:
            display_frame = cv2.convertScaleAbs(raw_display, alpha=1.0, beta=50)

        # ===== Common region calculation (same for tracking and align) =====
        h_img, w_img = frame.shape[:2]
        w_pct = cv2.getTrackbarPos("Region Width %", "Purple Laser Tracking")
        h_pct = cv2.getTrackbarPos("Region Height %", "Purple Laser Tracking")
        w_pct = max(1, w_pct)
        h_pct = max(1, h_pct)
        cx, cy = w_img // 2, h_img // 2
        half_w = int(w_img * w_pct / 200.0)
        half_h = int(h_img * h_pct / 200.0)
        rx1 = max(0, cx - half_w)
        ry1 = max(0, cy - half_h)
        rx2 = min(w_img, cx + half_w)
        ry2 = min(h_img, cy + half_h)

        # Draw region box
        cv2.rectangle(display_frame, (rx1, ry1), (rx2, ry2), (255, 255, 0), 2)

        if mode in ('tracking', 'purple'):
            # ===== TRACKING MODE: detect rect + purple, follow vertices =====
            corners, lines, _ = detect_black_rectangle_frame(frame, region=(rx1, ry1, rx2, ry2))
            if corners is not None:
                last_corners = corners

            center, mask = detect_purple_spot(frame, region=(rx1, ry1, rx2, ry2))

            if center is not None:
                if spot_lost_count > SPOT_LOST_RESET:
                          last_angle_yaw = YAW_CENTER
                          last_angle_pitch = PITCH_CENTER
                          print(">>> Spot reappeared after loss, reset last_angle to center")
                          if last_corners is not None:
                              send_alignment_packet(serial_port, center[0], center[1],
                                                    int(last_corners[0, 0]), int(last_corners[0, 1]))
                              print(">>> Sent wake-up alignment packet")
                cv2.circle(display_frame, center, 5, (0, 0, 255), -1)
                cv2.putText(display_frame, "Spot: %s" % (str(center),), (center[0] + 10, center[1] - 10),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 0), 2)

                if mode == 'tracking' and last_corners is not None:
                    poly = np.array(last_corners, dtype=np.int32)
                    pts_sorted = sort_corners_clockwise(poly)

                    # 锟斤拷始锟斤拷锟斤拷锟斤拷锟铰硷拷锟斤拷追锟斤拷目锟斤拷锟斤拷锟斤拷
                    if tracking_target_idx is None:
                        dists = np.linalg.norm(pts_sorted - np.array(center), axis=1)
                        tracking_target_idx = (int(np.argmin(dists)) + 1) % 4
                        print(">>> Tracking start: target V%d" % tracking_target_idx)
                    else:
                        # 锟斤拷锟斤拷欠竦酱锏鼻澳匡拷锟?                        cur_target = pts_sorted[tracking_target_idx]
                        dist_to_target = np.linalg.norm(np.array(center) - cur_target)

                        # 锟斤拷全锟斤拷锟斤拷锟斤拷锟侥匡拷锟教讹拷锟?300px锟斤拷锟斤拷锟斤拷锟斤拷偏锟斤拷路锟斤拷锟斤拷锟斤拷锟斤拷锟斤拷锟斤拷锟斤拷录锟斤拷锟?                        if dist_to_target > 300:
                            dists = np.linalg.norm(pts_sorted - np.array(center), axis=1)
                            nearest_idx = int(np.argmin(dists))
                            new_target = (nearest_idx + 1) % 4
                            if new_target != tracking_target_idx:
                                print(">>> Tracking lost, recalc target: V%d -> V%d" %
                                      (tracking_target_idx, new_target))
                                tracking_target_idx = new_target
                        elif dist_to_target < TRACKING_CONVERGE_PX:
                            old_idx = tracking_target_idx
                            tracking_target_idx = (tracking_target_idx + 1) % 4
                            print(">>> Reached V%d, advance to V%d" % (old_idx, tracking_target_idx))
                            # 锟斤拷锟斤拷锟絣ast_angle锟斤拷锟斤拷锟斤拷锟斤拷值锟斤拷锟斤拷锟斤拷锟斤拷锟斤拷

                    target_idx = tracking_target_idx
                    target_vertex = pts_sorted[target_idx]
                    cv2.line(display_frame, center, tuple(target_vertex), (0, 255, 255), 2)
                    cv2.circle(display_frame, tuple(target_vertex), 7, (0, 255, 255), -1)
                    cv2.putText(display_frame, "V%d" % target_idx,
                                (int(target_vertex[0]) + 8, int(target_vertex[1]) - 8),
                                cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 255), 2)

                    dx = target_vertex[0] - center[0]
                    dy = target_vertex[1] - center[1]
                    target_yaw   = last_angle_yaw   - dx * PIXEL_GAIN
                    target_pitch = last_angle_pitch - dy * PIXEL_GAIN

                    MAX_STEP = 0.2
                    dyaw = target_yaw - last_angle_yaw
                    if dyaw > MAX_STEP:
                        target_yaw = last_angle_yaw + MAX_STEP
                    elif dyaw < -MAX_STEP:
                        target_yaw = last_angle_yaw - MAX_STEP
                    dpitch = target_pitch - last_angle_pitch
                    if dpitch > MAX_STEP:
                        target_pitch = last_angle_pitch + MAX_STEP
                    elif dpitch < -MAX_STEP:
                        target_pitch = last_angle_pitch - MAX_STEP
                    last_angle_yaw = target_yaw
                    last_angle_pitch = target_pitch
                    send_angle_cmd(serial_port, target_yaw, target_pitch)

                    err_px = np.sqrt(dx**2 + dy**2)
                    cv2.putText(display_frame, "Track err: %.1fpx" % err_px,
                                (10, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 255), 2)
                    cv2.putText(display_frame, "Target:V%d Yaw:%.1f Pitch:%.1f" %
                                (target_idx, target_yaw, target_pitch),
                                (10, 55), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 255), 1)
                else:
                    send_spot_coordinates(serial_port, center[0], center[1])
                spot_lost_count = 0
            else:
                    spot_lost_count += 1
            if last_corners is not None and mode == 'tracking':
                poly_draw = np.array(last_corners, dtype=np.int32)
                cv2.polylines(display_frame, [poly_draw], True, (0, 0, 255), 2)

        else:
            # ===== ALIGN MODE: detect rect + purple, align to nearest vertex =====
            corners, lines, mask = detect_black_rectangle_frame(frame, region=(rx1, ry1, rx2, ry2))
            purple_center, purple_mask = detect_purple_spot(frame, region=(rx1, ry1, rx2, ry2))

            if purple_center is not None:
                if spot_lost_count > SPOT_LOST_RESET:
                    last_angle_yaw = YAW_CENTER
                    last_angle_pitch = PITCH_CENTER
                    print(">>> Spot reappeared after loss, reset last_angle to center")
                    # 锟斤拷锟斤拷0x06锟斤拷准锟斤拷锟斤拷锟斤拷STM32锟斤拷锟斤拷锟絧urple_lost_flag锟斤拷锟街革拷锟斤拷锟斤拷0x08指锟筋）
                    if corners is not None:
                        send_alignment_packet(serial_port, purple_center[0], purple_center[1],
                                              corners[0][0], corners[0][1])
                        print(">>> Sent wake-up alignment packet")
                spot_lost_count = 0
                cv2.circle(display_frame, purple_center, 5, (255, 0, 255), -1)
                cv2.putText(display_frame, "Purple: %s" % (str(purple_center),),
                            (purple_center[0] + 10, purple_center[1] - 10),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 255, 255), 2)

                if corners is not None:
                    pts = np.array(corners, dtype=np.int32)
                    dists = np.linalg.norm(pts - np.array(purple_center), axis=1)
                    nearest_idx = int(np.argmin(dists))
                    nearest_vertex = pts[nearest_idx]

                    cv2.line(display_frame, purple_center, tuple(nearest_vertex), (0, 255, 255), 1)

                    dx = nearest_vertex[0] - purple_center[0]
                    dy = nearest_vertex[1] - purple_center[1]

                    target_yaw   = last_angle_yaw   - dx * PIXEL_GAIN
                    target_pitch = last_angle_pitch - dy * PIXEL_GAIN

                    MAX_STEP = 0.2
                    dyaw = target_yaw - last_angle_yaw
                    if dyaw > MAX_STEP:
                        target_yaw = last_angle_yaw + MAX_STEP
                    elif dyaw < -MAX_STEP:
                        target_yaw = last_angle_yaw - MAX_STEP
                    dpitch = target_pitch - last_angle_pitch
                    if dpitch > MAX_STEP:
                        target_pitch = last_angle_pitch + MAX_STEP
                    elif dpitch < -MAX_STEP:
                        target_pitch = last_angle_pitch - MAX_STEP

                    last_angle_yaw = target_yaw
                    last_angle_pitch = target_pitch

                    send_angle_cmd(serial_port, target_yaw, target_pitch)
                    err_px = np.sqrt(dx**2 + dy**2)
                    cv2.putText(display_frame, "Align err: %.1fpx" % err_px,
                                (10, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 255), 2)
                    cv2.putText(display_frame, "Yaw:%.1f Pitch:%.1f" % (target_yaw, target_pitch),
                                (10, 55), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 255), 1)
            else:
                spot_lost_count += 1
            if corners is not None:
                last_corners = corners
                poly = np.array(corners, dtype=np.int32)
                cv2.polylines(display_frame, [poly], True, (0, 0, 255), 2)
                for (x, y) in poly:
                    cv2.circle(display_frame, (int(x), int(y)), 4, (0, 255, 0), -1)
                cv2.putText(display_frame, "RotRect",
                            (int(poly[0, 0]), max(int(poly[0, 1]) - 10, 0)),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 0), 2)
                if last_sent_rect is None or not rects_are_similar(last_sent_rect, poly):
                    send_rotated_rect_coordinates(serial_port, poly)
                    last_sent_rect = poly.copy()
                else:
                    print("Rect stable, suppress repeat send")
            elif lines:
                for (x1, y1, x2, y2) in lines:
                    cv2.line(display_frame, (x1, y1), (x2, y2), (0, 0, 255), 2)
            mask = mask if mask is not None else purple_mask

        cv2.imshow("Purple Laser Tracking", display_frame)
        cv2.imshow("Purple Mask", mask)

        if cv2.waitKey(1) & 0xFF == ord('q'):
            break

    picam2.stop()
    if serial_port is not None:
        serial_port.close()
    cv2.destroyAllWindows()


if __name__ == "__main__":
    main()
