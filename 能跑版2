def build_mode_ctrl_packet(mode):
    payload = struct.pack("<BB", PACKET_ID_MODE_CTRL, mode)
    checksum = sum(payload) & 0xFF
    packet = bytes([START_BYTE]) + payload + bytes([checksum, END_BYTE])
    return packet
def send_mode_ctrl(ser, mode):
    if ser is None:
        return
    ensure_send_interval()
    packet = build_mode_ctrl_packet(mode)
    try:
        ser.write(packet)
        ser.flush()
        print(">>> Send mode ctrl: mode=%d (%s), packet=%s" %
              (mode, "align" if mode == 0 else "tracking", packet.hex()))
    except serial.SerialException as exc:
        print("Serial send failed: %s" % exc)


