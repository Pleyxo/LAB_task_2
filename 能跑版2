def build_angle_cmd_packet(yaw_angle, pitch_angle):
    yaw_int = int(max(-32768, min(32767, round(yaw_angle * 100))))
    pitch_int = int(max(-32768, min(32767, round(pitch_angle * 100))))
    payload = struct.pack("<Bhh", PACKET_ID_ANGLE_CMD, yaw_int, pitch_int)
    checksum = sum(payload) & 0xFF
    packet = bytes([START_BYTE]) + payload + bytes([checksum, END_BYTE])
    return packet


def send_angle_cmd(ser, yaw, pitch):
    if ser is None:
        return
    ensure_send_interval()
    packet = build_angle_cmd_packet(yaw, pitch)
    try:
        ser.write(packet)
        ser.flush()
        print(">>> Angle cmd: yaw=%.1f, pitch=%.1f" % (yaw, pitch))
    except serial.SerialException as exc:
        print("Serial send failed: %s" % exc)


def detect_purple_spot(frame, region=None):
    hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)
    lower_purple = np.array([95, 50, 20])
    upper_purple = np.array([135, 250, 255])
    mask = cv2.inRange(hsv, lower_purple, upper_purple)
    kernel = np.ones((5, 5), np.uint8)
    mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, kernel)
    mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, kernel)
    if region is not None:
        try:
            h_img, w_img = mask.shape
            rx1, ry1, rx2, ry2 = map(int, region)
            rx1 = max(0, min(w_img, rx1))
            rx2 = max(0, min(w_img, rx2))
            ry1 = max(0, min(h_img, ry1))
            ry2 = max(0, min(h_img, ry2))
            region_mask = np.zeros_like(mask)
            if ry2 > ry1 and rx2 > rx1:
                region_mask[ry1:ry2, rx1:rx2] = 255
            mask = cv2.bitwise_and(mask, region_mask)
        except Exception:
            pass
    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    if contours:
        largest = max(contours, key=cv2.contourArea)
        area = cv2.contourArea(largest)
        if area > 5:
            (x, y), radius = cv2.minEnclosingCircle(largest)
            return (int(x), int(y)), mask
    return None, mask
def rects_are_similar(prev_corners, curr_corners, max_center_shift=8, max_area_ratio=0.15):
    if prev_corners is None or curr_corners is None:
        return False
    prev = np.asarray(prev_corners, dtype=np.float32).reshape(4, 2)
    curr = np.asarray(curr_corners, dtype=np.float32).reshape(4, 2)
    prev_center = np.mean(prev, axis=0)
    curr_center = np.mean(curr, axis=0)
    center_dist = np.linalg.norm(prev_center - curr_center)
    if center_dist > max_center_shift:
        return False
    prev_area = abs(cv2.contourArea(prev.reshape(4, 1, 2)))
    curr_area = abs(cv2.contourArea(curr.reshape(4, 1, 2)))
    if prev_area <= 0 or curr_area <= 0:
        return False
    if abs(prev_area - curr_area) / max(prev_area, curr_area) > max_area_ratio:
        return False
    return True
def sort_corners_clockwise(corners):
    corners = sorted(corners, key=lambda p: p[1])
    top = sorted(corners[:2], key=lambda p: p[0])
    bottom = sorted(corners[2:], key=lambda p: p[0], reverse=True)
    return np.array(top + bottom, dtype=np.int32)


def detect_black_rectangle_frame(frame,
                                 region=None,
                                 threshold_value=80,
                                 min_area_ratio=0.01,
                                 min_side_ratio=0.09,
                                 max_aspect_ratio=2.0,
                                 max_angle_error=25.0):
    def is_rectangle(corners):
        corners = corners.reshape(4, 2).astype(np.float32)
        corners = sort_corners_clockwise(corners)
        for i in range(4):
            p0 = corners[i]
            p1 = corners[(i + 1) % 4]
            p2 = corners[(i + 2) % 4]
            v1 = p0 - p1
            v2 = p2 - p1
            norm1 = np.linalg.norm(v1)
            norm2 = np.linalg.norm(v2)
            if norm1 < 1e-6 or norm2 < 1e-6:
                return False
            cos_angle = abs(np.dot(v1, v2) / (norm1 * norm2))
            if cos_angle > np.cos(np.deg2rad(max_angle_error)):
                return False
        return True

    h_img, w_img = frame.shape[:2]
    rx1 = ry1 = rx2 = ry2 = None
    roi = frame

    if region is not None:
        try:
            rx1, ry1, rx2, ry2 = map(int, region)
            rx1 = max(0, min(w_img, rx1))
            rx2 = max(0, min(w_img, rx2))
            ry1 = max(0, min(h_img, ry1))
            ry2 = max(0, min(h_img, ry2))
            if ry2 > ry1 and rx2 > rx1:
                roi = frame[ry1:ry2, rx1:rx2]
        except Exception:
            roi = frame

    gray = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)
    blur = cv2.GaussianBlur(gray, (7, 7), 0)
    equalized = cv2.equalizeHist(blur)

    _, thresh = cv2.threshold(equalized, threshold_value, 255,
                              cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU)
    adapt = cv2.adaptiveThreshold(equalized, 255,
                                  cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
                                  cv2.THRESH_BINARY_INV, 11, 4)
    mask = cv2.bitwise_or(thresh, adapt)
    kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (3, 3))
    mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, kernel, iterations=1)
    mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, kernel, iterations=1)
    edges = cv2.Canny(mask, 20, 100)
    edges = cv2.dilate(edges, kernel, iterations=1)

    h_roi, w_roi = gray.shape
    min_area = max(1, w_roi * h_roi * min_area_ratio)
    min_side = max(1, min(w_roi, h_roi) * min_side_ratio)

    contours, _ = cv2.findContours(edges, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    best_corners = None
    best_score = 0
    full_mask = np.zeros((h_img, w_img), dtype=np.uint8)
    if region is not None and rx1 is not None:
        full_mask[ry1:ry2, rx1:rx2] = mask
    else:
        full_mask = mask

    for cnt in contours:
        area = cv2.contourArea(cnt)
        if area < min_area:
            continue

        peri = cv2.arcLength(cnt, True)
        approx = cv2.approxPolyDP(cnt, 0.02 * peri, True)
        if len(approx) != 4 or not cv2.isContourConvex(approx):
            continue

        corners = approx.reshape(4, 2).astype(np.int32)
        x, y, w, h = cv2.boundingRect(corners)
        if w < min_side or h < min_side:
            continue

        aspect_ratio = max(w, h) / min(w, h)
        if aspect_ratio > max_aspect_ratio:
            continue

        if not is_rectangle(corners):
            rect = cv2.minAreaRect(cnt)
            corners = np.int32(cv2.boxPoints(rect))
            if not is_rectangle(corners):
                continue
            x, y, w, h = cv2.boundingRect(corners)
            if w < min_side or h < min_side:
                continue

        rect_area = float(w * h)
        fill_ratio = area / rect_area if rect_area > 0 else 0
        if fill_ratio < 0.35:
            continue

        if region is not None and rx1 is not None:
            if np.any(corners[:, 0] < 0) or np.any(corners[:, 0] >= w_roi) or np.any(corners[:, 1] < 0) or np.any(corners[:, 1] >= h_roi):
                continue

        score = fill_ratio * area
        if score > best_score:
            best_score = score
            best_corners = corners

    if best_corners is None and contours:
        for cnt in sorted(contours, key=cv2.contourArea, reverse=True)[:3]:
            area = cv2.contourArea(cnt)
            if area < min_area:
                continue
            rect = cv2.minAreaRect(cnt)
            box = np.int32(cv2.boxPoints(rect))
            x, y, w, h = cv2.boundingRect(box)
            if w < min_side or h < min_side:
                continue
            aspect_ratio = max(w, h) / min(w, h)
            if aspect_ratio > max_aspect_ratio:
                continue
            if not is_rectangle(box):
                continue
            rect_area = float(w * h)
            fill_ratio = area / rect_area if rect_area > 0 else 0
            if fill_ratio < 0.35:
                continue
            best_corners = box
            break
    if best_corners is not None:
        if region is not None and rx1 is not None:
            best_corners = best_corners + np.array([rx1, ry1])
        best_corners = sort_corners_clockwise(best_corners)
        EXPAND_PX = 6
        center = np.mean(best_corners, axis=0)
        for i in range(4):
                  vec = best_corners[i] - center
                  norm = np.linalg.norm(vec)
                  if norm > 1e-6:
                      best_corners[i] = best_corners[i] + vec / norm * EXPAND_PX

    lines = []
    if best_corners is not None:
        for i in range(4):
            x1, y1 = int(best_corners[i, 0]), int(best_corners[i, 1])
            x2, y2 = int(best_corners[(i + 1) % 4, 0]), int(best_corners[(i + 1) % 4, 1])
            lines.append((x1, y1, x2, y2))

    return best_corners, lines, full_mask


def stdin_listener(mode_holder, serial_port=None):
    print("=" * 50)
    print("  Terminal control:")
    print("    0 -> align mode: detect rect + purple, send angle cmd")
    print("    1 -> tracking mode: follow vertices clockwise")
    print("=" * 50)
    while True:
        try:
            s = sys.stdin.readline()
            if not s:
                break
            s = s.strip()
            if s == '0':
                mode_holder['mode'] = 'align'
                send_mode_ctrl(serial_port, 0)
                print(">>> Mode: align (calibration)")
            elif s == '1':
                mode_holder['mode'] = 'tracking'
                send_mode_ctrl(serial_port, 1)
                print(">>> Mode: tracking (vertex follow)")
        except Exception:
            break


