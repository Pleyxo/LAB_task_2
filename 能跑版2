ENABLE_SERIAL = os.getenv("ENABLE_SERIAL", "1") != "0"
START_BYTE = 0xAA
END_BYTE = 0x55
PACKET_ID = 0x01
PACKET_ID_RECT = 0x02
PACKET_ID_ROT_RECT = 0x03
PACKET_ID_ALIGN = 0x06
PACKET_ID_MODE_CTRL = 0x07
PACKET_ID_ANGLE_CMD = 0x08
SEND_MIN_INTERVAL = 0.04
_last_send_time = 0.0


def build_laser_packet(x, y):
    x = int(max(0, min(65535, round(x))))
    y = int(max(0, min(65535, round(y))))
    payload = struct.pack("<BHH", PACKET_ID, x, y)
    checksum = sum(payload) & 0xFF
    packet = bytes([START_BYTE]) + payload + bytes([checksum, END_BYTE])
    return packet


def build_rect_packet(x1, y1, x2, y2):
    x1 = int(max(0, min(65535, round(x1))))
    y1 = int(max(0, min(65535, round(y1))))
    x2 = int(max(0, min(65535, round(x2))))
    y2 = int(max(0, min(65535, round(y2))))
    payload = struct.pack("<BHHHH", PACKET_ID_RECT, x1, y1, x2, y2)
    checksum = sum(payload) & 0xFF
    packet = bytes([START_BYTE]) + payload + bytes([checksum, END_BYTE])
    return packet


def build_rot_rect_packet(corners):
    corners = np.asarray(corners, dtype=np.int64).reshape(4, 2)
    corners = np.clip(np.round(corners), 0, 65535).astype(np.uint16)
    payload = struct.pack("<BHHHHHHHH",
                          PACKET_ID_ROT_RECT,
                          int(corners[0, 0]), int(corners[0, 1]),
                          int(corners[1, 0]), int(corners[1, 1]),
                          int(corners[2, 0]), int(corners[2, 1]),
                          int(corners[3, 0]), int(corners[3, 1]))
    checksum = sum(payload) & 0xFF
    packet = bytes([START_BYTE]) + payload + bytes([checksum, END_BYTE])
    return packet


def build_alignment_packet(purple_x, purple_y, target_x, target_y):
    purple_x = int(max(0, min(65535, round(purple_x))))
    purple_y = int(max(0, min(65535, round(purple_y))))
    target_x = int(max(0, min(65535, round(target_x))))
    target_y = int(max(0, min(65535, round(target_y))))
    payload = struct.pack("<BHHHH", PACKET_ID_ALIGN,
                          purple_x, purple_y, target_x, target_y)
    checksum = sum(payload) & 0xFF
    packet = bytes([START_BYTE]) + payload + bytes([checksum, END_BYTE])
    return packet


def open_serial_port(port=SERIAL_PORT, baudrate=BAUDRATE, timeout=SERIAL_TIMEOUT):
    if serial is None:
        print("Warning: pyserial not installed")
        return None
    try:
        ser = serial.Serial(port, baudrate=baudrate, timeout=timeout)
        print("Serial opened: %s @ %d" % (port, baudrate))
        return ser
    except serial.SerialException as exc:
        print("Cannot open serial %s: %s" % (port, exc))
        return None
def ensure_send_interval():
    global _last_send_time
    now = time.monotonic()
    elapsed = now - _last_send_time
    if elapsed < SEND_MIN_INTERVAL:
        time.sleep(SEND_MIN_INTERVAL - elapsed)
    _last_send_time = time.monotonic()


def send_spot_coordinates(ser, x, y):
    if ser is None:
        return
    ensure_send_interval()
    packet = build_laser_packet(x, y)
    try:
        ser.write(packet)
        ser.flush()
        print("Send spot: x=%d, y=%d, packet=%s" % (int(x), int(y), packet.hex()))
    except serial.SerialException as exc:
        print("Serial send failed: %s" % exc)


def send_rect_coordinates(ser, x1, y1, x2, y2):
    if ser is None:
        return
    ensure_send_interval()
    packet = build_rect_packet(x1, y1, x2, y2)
    try:
        ser.write(packet)
        ser.flush()
        print("Send rect: x1=%d, y1=%d, x2=%d, y2=%d, packet=%s" %
              (int(x1), int(y1), int(x2), int(y2), packet.hex()))
    except serial.SerialException as exc:
        print("Serial send failed: %s" % exc)


def send_rotated_rect_coordinates(ser, corners):
    if ser is None:
        return
    ensure_send_interval()
    packet = build_rot_rect_packet(corners)
    try:
        ser.write(packet)
        ser.flush()
        pts = [tuple(int(v) for v in pt) for pt in np.asarray(corners, dtype=np.int32)]
        print("Send rotated rect: %s, packet=%s" % (pts, packet.hex()))
    except serial.SerialException as exc:
        print("Serial send failed: %s" % exc)


def send_alignment_packet(ser, purple_x, purple_y, target_x, target_y):
    if ser is None:
        return
