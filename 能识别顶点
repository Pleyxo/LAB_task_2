def ensure_send_interval():
    global _last_send_time
    now = time.monotonic()
    elapsed = now - _last_send_time
    if elapsed < SEND_MIN_INTERVAL:
        time.sleep(SEND_MIN_INTERVAL - elapsed)
    _last_send_time = time.monotonic()


