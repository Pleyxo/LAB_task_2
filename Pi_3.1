# ===================== 锟斤拷锟斤拷锟节匡拷直锟斤拷锟睫改的诧拷锟斤拷锟斤拷锟斤拷=====================
# 1. 锟斤拷维锟斤拷台2锟斤拷锟斤拷锟斤拷某锟绞硷拷嵌炔锟斤拷锟斤拷锟斤拷锟絊TM32锟剿憋拷锟斤拷一锟铰硷拷锟缴ｏ拷
INIT_PITCH_ANGLE = 22.5  # 锟斤拷始锟斤拷锟斤拷锟角讹拷
INIT_YAW_ANGLE = 35.0    # 锟斤拷始偏锟斤拷锟角讹拷

# 2. 模式一锟斤拷锟斤拷锟斤拷锟轿边筹拷锟斤拷锟斤拷锟斤拷锟斤拷位锟斤拷锟阶ｏ拷
SQUARE_SIDE_METER = 0.8  # 默锟斤拷0.5锟阶ｏ拷锟睫改此达拷锟斤拷锟缴碉拷锟斤拷锟竭筹拷
