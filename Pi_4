INIT_YAW_ANGLE = 35.0    # 初始偏航角度

# 模式1正方形边长（单位：米，与STM32端SQUARE_SIDE_METER对应）
SQUARE_SIDE_METER = 0.5  # 正方形边长，默认0.5米

# 摄像头分辨率（需与STM32端CAM_WIDTH/CAM_HEIGHT一致）
CAM_WIDTH = 480
CAM_HEIGHT = 320

# 正方形区域映射到图像的范围（归一化到图像像素）
# 计算逻辑：将STM32端0~65535的归一化坐标映射到480x320像素
SQUARE_CENTER_X_PX = CAM_WIDTH / 2
SQUARE_CENTER_Y_PX = CAM_HEIGHT / 2
SQUARE_HALF_SCALE_PX = (min(CAM_WIDTH, CAM_HEIGHT) * SQUARE_SIDE_METER) / 1.0  # 1.0为最大量程
SQUARE_LEFT = int(SQUARE_CENTER_X_PX - SQUARE_HALF_SCALE_PX / 2)
SQUARE_RIGHT = int(SQUARE_CENTER_X_PX + SQUARE_HALF_SCALE_PX / 2)
SQUARE_TOP = int(SQUARE_CENTER_Y_PX - SQUARE_HALF_SCALE_PX / 2)
SQUARE_BOTTOM = int(SQUARE_CENTER_Y_PX + SQUARE_HALF_SCALE_PX / 2)
# 确保区域在图像范围内
SQUARE_LEFT = max(0, SQUARE_LEFT)
SQUARE_RIGHT = min(CAM_WIDTH - 1, SQUARE_RIGHT)
SQUARE_TOP = max(0, SQUARE_TOP)
SQUARE_BOTTOM = min(CAM_HEIGHT - 1, SQUARE_BOTTOM)
